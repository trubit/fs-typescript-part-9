{
  "name": "healthapp",
  "version": "1.0.0",
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "start": "npm run build && node build/src/index.js",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "lint": "eslint .",
    "calculateBmi": "ts-node-dev --transpile-only bmiCalculator.ts",
    "calculateExercises": "ts-node-dev --transpile-only exerciseCalculator.ts"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/express": "^5.0.6",
    "@types/node": "^25.9.3",
    "eslint": "^10.4.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0"
  },
  "dependencies": {
    "express": "^5.2.1"
  }
}
